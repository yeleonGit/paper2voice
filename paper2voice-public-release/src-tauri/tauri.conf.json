{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Paper2Voice",
  "version": "0.1.0",
  "identifier": "com.paper2voice.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Paper2Voice",
        "label": "main",
        "width": 1120,
        "height": 820,
        "resizable": true,
        "theme": "Dark",
        "titleBarStyle": "Transparent",
        "hiddenTitle": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["$HOME/**", "/Volumes/**"]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "resources": {
      "../models/kokoro-v1.0.onnx": "models/kokoro-v1.0.onnx",
      "../models/voices-v1.0.bin": "models/voices-v1.0.bin",
      "../scripts/kokoro_bridge.py": "scripts/kokoro_bridge.py",
      "../scripts/requirements-kokoro.txt": "scripts/requirements-kokoro.txt",
      "../runtime/python": "runtime/python",
      "../runtime/site-packages": "runtime/site-packages"
    }
  }
}
